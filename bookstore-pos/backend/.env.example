# =============================================================================
# CONFIGURACIÓN DEL BACKEND - BOOKSTORE POS
# =============================================================================
# Copie este archivo a .env y ajuste los valores según su entorno.
# NUNCA commita el archivo .env con valores reales de producción.
# =============================================================================

# -----------------------------------------------------------------------------
# SEGURIDAD Y AUTENTICACIÓN
# -----------------------------------------------------------------------------
# JWT_SECRET: OBLIGATORIO. Clave secreta para firmar tokens JWT.
# Use un valor único y seguro (mínimo 32 caracteres). Genere con:
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=cambie_esto_por_un_valor_segur_aleatorio_minimo_32_caracteres

# DATABASE_URL: URL de conexión a la base de datos
# SQLite (desarrollo): sqlite+aiosqlite:///./bookstore.db
# PostgreSQL (producción): postgresql+asyncpg://user:pass@localhost:5432/bookstore
DATABASE_URL=sqlite+aiosqlite:///./bookstore.db

# CORS_ORIGINS: Orígenes permitidos para CORS (separados por comas)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# TOKENS Y SESIONES
# -----------------------------------------------------------------------------
# Duración del token de acceso en minutos (default: 45)
ACCESS_TOKEN_EXPIRE_MINUTES=45

# Duración del token de refresco en minutos (default: 20160 = 14 días)
REFRESH_TOKEN_EXPIRE_MINUTES=20160

# -----------------------------------------------------------------------------
# ENTORNO Y COOKIES
# -----------------------------------------------------------------------------
# ENVIRONMENT: dev, prod, production
ENVIRONMENT=dev

# COOKIE_SECURE: true en producción (requiere HTTPS)
COOKIE_SECURE=false

# COOKIE_SAMESITE: lax, strict, none
COOKIE_SAMESITE=lax

# COOKIE_DOMAIN: Dominio para cookies (vacío = dominio actual)
COOKIE_DOMAIN=

# Nombres de cookies y headers
REFRESH_COOKIE_NAME=refresh_token
REQUEST_ID_HEADER_NAME=x-request-id

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Límite general de peticiones por minuto
RATE_LIMIT_PER_MINUTE=120

# Ventana de tiempo para rate limiting en segundos
RATE_LIMIT_WINDOW_SECONDS=60

# Máximo de intentos de login por ventana
AUTH_LOGIN_RATE_LIMIT_COUNT=10

# Ventana de tiempo para intentos de login en segundos
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# -----------------------------------------------------------------------------
# SEGURIDAD DE CONTRASEÑAS Y 2FA
# -----------------------------------------------------------------------------
# Longitud mínima de contraseñas
PASSWORD_MIN_LENGTH=10

# Requisitos de complejidad de contraseña
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true

# TWOFA_ENCRYPTION_KEY: Clave para encriptar secretos 2FA (requerida en producción)
# Genere con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TWOFA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# ENDPOINTS DE SALUD Y MÉTRICAS
# -----------------------------------------------------------------------------
# Si true, solo responden desde localhost en producción
HEALTH_ALLOW_LOCAL_ONLY=true
METRICS_ALLOW_LOCAL_ONLY=true

# -----------------------------------------------------------------------------
# ADMIN INICIAL (BOOTSTRAP)
# -----------------------------------------------------------------------------
# BOOTSTRAP_DEV_ADMIN: true para crear admin por defecto en desarrollo
BOOTSTRAP_DEV_ADMIN=false

# Credenciales del admin inicial (dejar vacío si no usa bootstrap)
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# IMPORTACIÓN DE INVENTARIO
# -----------------------------------------------------------------------------
# Tamaño máximo de archivos de importación en MB
INVENTORY_IMPORT_MAX_FILE_SIZE_MB=25

# Tamaño de lote por defecto para imports
INVENTORY_IMPORT_DEFAULT_BATCH_SIZE=200

# Tamaño máximo de lote para imports
INVENTORY_IMPORT_MAX_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# PROGRAMA DE LEALTAD
# -----------------------------------------------------------------------------
# Puntos de lealtad por unidad monetaria
LOYALTY_POINTS_PER_CURRENCY_UNIT=1.0

# Valor de cada punto de lealtad en moneda
LOYALTY_POINT_VALUE=0.05

# Puntos mínimos para redimir
LOYALTY_MIN_REDEEM_POINTS=50

# -----------------------------------------------------------------------------
# BLOQUEO DE CUENTAS
# -----------------------------------------------------------------------------
# Intentos fallidos antes de bloquear cuenta
ACCOUNT_LOCK_THRESHOLD=5

# Minutos de bloqueo tras intentos fallidos
ACCOUNT_LOCK_MINUTES=15

# -----------------------------------------------------------------------------
# REDIS (OPCIONAL)
# -----------------------------------------------------------------------------
# URL de conexión a Redis para rate limiting distribuido
# Dejar vacío para usar rate limiting en memoria
REDIS_URL=
