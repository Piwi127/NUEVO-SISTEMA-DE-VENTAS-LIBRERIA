{
  "venvPath": "backend",
  "venv": ".venv",
  "include": [
    "backend/app",
    "backend/tests",
    "scripts"
  ],
  "exclude": [
    "**/__pycache__",
    "backend/.venv",
    "frontend",
    "monitoring",
